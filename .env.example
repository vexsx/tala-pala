# Copy to .env and change every secret before deploying. NEVER commit .env.
# Each secret also supports a *_FILE variant pointing at a mounted file.

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=goldpred
POSTGRES_USER=goldpred
POSTGRES_PASSWORD=change-me-strong-password
# Optional: file-based secret (overrides POSTGRES_PASSWORD if set)
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password

# ---------- Redis ----------
REDIS_ADDR=redis:6379

# ---------- Shared service-to-service auth ----------
# Random 32+ char token; Go sends it to the Python service.
INTERNAL_API_TOKEN=change-me-random-internal-token

# ---------- Go API ----------
API_PORT=8080
JWT_SECRET=change-me-random-jwt-secret-at-least-32-chars
JWT_TTL_HOURS=24
# First registered user becomes admin. Keep false so only the admin can add users.
ALLOW_OPEN_REGISTRATION=false
PREDICTION_SERVICE_URL=http://prediction-service:8500
SCHEDULER_ENABLED=true
RATE_LIMIT_RPM=60
CORS_ALLOWED_ORIGINS=http://localhost:8088
LOG_LEVEL=info
# Cron overrides (standard 5-field cron, UTC)
SCHEDULE_COLLECT_CRON=*/10 * * * *
SCHEDULE_PREDICT_CRON=5 * * * *
SCHEDULE_SIGNALS_CRON=10 * * * *
SCHEDULE_EVALUATE_CRON=20 * * * *
SCHEDULE_TRAIN_CRON=30 2 * * *
SCHEDULE_ALERTS_CRON=*/5 * * * *
SCHEDULE_CLEANUP_CRON=0 4 * * *

# ---------- Python prediction service ----------
PREDICTION_PORT=8500
MODELS_DIR=/app/models
HTTP_TIMEOUT_SECONDS=15
RAW_RETENTION_DAYS=365
STALE_MINUTES=30
# Optional paid/keyed providers (leave empty to disable)
NAVASAN_API_KEY=
METALS_DEV_API_KEY=
BRSAPI_KEY=
ALANCHAND_TOKEN=

# Tehran market hours (Asia/Tehran local; Sat-Wed, Thursday and Friday closed).
# Applies to windowed Iranian symbols (USD_IRT, IR_COIN_EMAMI); IR_GOLD_18K
# trades 24h on trading days and ignores this window.
# Outside these hours Iranian prices are shown as "market closed", not "stale".
MARKET_TEHRAN_OPEN=12:00
MARKET_TEHRAN_CLOSE=20:00

# ---------- Frontend ----------
FRONTEND_PORT=8088

# --- Tehran-exchange gold funds (Addendum 7) ---------------------------------
# Fund quotes + retail/institutional flow come from BrsApi's TSETMC mirror
# (tsetmc.com is geo-blocked outside Iran) and REUSE BRSAPI_KEY above; the
# tse_funds provider stays dormant until that key is set (free key:
# https://brsapi.ir/tsetmc-exchange-free-bourse-api-key-request/).
# Funds to track, "ticker:SYMBOL" pairs (symbols must start with IR_GOLD_FUND):
#TSETMC_FUNDS=عیار:IR_GOLD_FUND_AYAR,طلا:IR_GOLD_FUND_TALA,کهربا:IR_GOLD_FUND_KAHRABA
# TSE fund session, Asia/Tehran local (Sat-Wed; Thursday and Friday closed):
MARKET_TSE_OPEN=12:00
MARKET_TSE_CLOSE=17:00
# Tehran-local fetch slots for fund quotes (quota: 2 requests per slot).
# 18:00 is deliberately post-close to capture the settled closing data.
TSETMC_FETCH_TIMES=12:00,15:00,18:00
